{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Location for all resources"
      }
    },
    "o365ConnectionName": {
      "type": "string",
      "defaultValue": "office365-sdc",
      "metadata": {
        "description": "Name for the Office 365 API connection"
      }
    },
    "githubConnectionName": {
      "type": "string",
      "defaultValue": "github-sdc",
      "metadata": {
        "description": "Name for the GitHub API connection"
      }
    }
  },
  "resources": [
    {
      "type": "Microsoft.Web/connections",
      "apiVersion": "2016-06-01",
      "name": "[parameters('o365ConnectionName')]",
      "location": "[parameters('location')]",
      "properties": {
        "displayName": "SmartDrivingCar O365 Newsletter",
        "api": {
          "id": "[subscriptionResourceId('Microsoft.Web/locations/managedApis', parameters('location'), 'office365')]"
        }
      }
    },
    {
      "type": "Microsoft.Web/connections",
      "apiVersion": "2016-06-01",
      "name": "[parameters('githubConnectionName')]",
      "location": "[parameters('location')]",
      "properties": {
        "displayName": "SmartDrivingCar GitHub",
        "api": {
          "id": "[subscriptionResourceId('Microsoft.Web/locations/managedApis', parameters('location'), 'github')]"
        }
      }
    }
  ],
  "outputs": {
    "o365ConnectionId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Web/connections', parameters('o365ConnectionName'))]"
    },
    "githubConnectionId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Web/connections', parameters('githubConnectionName'))]"
    }
  }
}
